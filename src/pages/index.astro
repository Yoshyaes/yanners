---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import SectionHead from "../components/SectionHead.astro";
import WorkGrid from "../components/WorkGrid.astro";
import VideoChips from "../components/VideoChips.astro";
import VideoModal from "../components/VideoModal.astro";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <Nav />
  <Hero />

  <main id="main">
    <div class="wrap">
      <section id="work" class="reveal">
        <SectionHead
          eyebrow="Selected Work"
          heading="A few favorites."
          deck="Click any piece to read it."
        />

        <WorkGrid />

        <VideoChips />

        <p class="work-foot">
          Real bylines, all live. <a
            href="https://muckrack.com/ayanna-redwood-crawford-1"
            target="_blank"
            rel="noopener">See the full archive</a
          >
        </p>
      </section>

      <About />
    </div>
  </main>

  <Footer />

  <VideoModal />
</Base>
